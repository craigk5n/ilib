# clang-tidy configuration for Ilib.
#
# Scoped to bug-finding checks that matter for a C image library handling
# untrusted file input: the static analyzer, bugprone-*, and a few cert/misc
# memory-safety checks. Style/readability/modernize checks are intentionally
# left off — this is legacy K&R-derived C and those would be pure noise.
#
# The CI job runs with --warnings-as-errors, so this baseline must stay clean.
# Disabled checks below are either non-portable to "fix", idiomatic for this
# codebase, or tracked as separate follow-ups (noted inline).
Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  cert-flp30-c,
  misc-misplaced-const,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-assignment-in-if-condition,
  -bugprone-reserved-identifier,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-multi-level-implicit-pointer-conversion,
  -bugprone-branch-clone,
  -bugprone-switch-missing-default-case,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -clang-analyzer-security.insecureAPI.strcpy
WarningsAsErrors: '*'
HeaderFilterRegex: 'src/.*\.h$'
FormatStyle: none

# Rationale for the disabled checks:
#   bugprone-reserved-identifier / cert-dcl37-c / cert-dcl51-cpp
#     - The "_I" private-symbol prefix is an intrinsic, pervasive convention.
#   bugprone-implicit-widening-of-multiplication-result
#     - Pixel index/size math is bounded by ILIB_MAX_PIXELS (1<<27) in
#       ICreateImage and by per-decoder dimension validation, so the int
#       multiplications cannot overflow. The one unbounded site (BDF glyph
#       allocation) is validated explicitly (IFONT_MAX_GLYPH_DIM).
#   bugprone-multi-level-implicit-pointer-conversion
#     - Idiomatic void**/T** conversions in C.
#   bugprone-branch-clone / bugprone-switch-missing-default-case
#     - Stylistic; the duplicate/defaultless branches here are intentional.
#   clang-analyzer-security.insecureAPI.{DeprecatedOrUnsafeBufferHandling,strcpy}
#     - Demand C11 Annex K *_s functions, which are not portable across the
#       glibc/macOS targets. Replacing the unsafe string ops is tracked as a
#       separate hardening pass.
#   cert-err34-c (not enabled)
#     - Unchecked atoi/sscanf in the parsers; tightening conversion-error
#       handling is a separate focused effort (it changes parse strictness).
