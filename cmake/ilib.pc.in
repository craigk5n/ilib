# Relocatable: derive the prefix from this file's own location so the .pc is
# correct regardless of the install prefix (including `cmake --install --prefix`).
prefix=${pcfiledir}/@ILIB_PC_REL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@
# Directory holding the bundled X11 BDF fonts (pass to ILoadFontFromFile()).
fontdir=${prefix}/@CMAKE_INSTALL_DATADIR@/ilib/fonts

Name: Ilib
Description: @PROJECT_DESCRIPTION@
URL: @PROJECT_HOMEPAGE_URL@
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lilib
# Libs.private lists the transitive dependencies needed for *static* linking;
# the codec entries reflect which optional backends were enabled at build time.
Libs.private: @ILIB_PC_PRIVATE_LIBS@
Cflags: -I${includedir}
