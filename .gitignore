# CMake build directories
/build/
/build-*/
CMakeUserPresets.json

# Compiled objects and libraries
*.o
*.O
*.a
*.lo
*.la
*.so
*.so.*
*.dylib
.libs/
.deps/

# Editor backups
*~
*.swp

# Generated font headers (produced by ifont2h from .bdf fonts)
helv*.h
cour*.h

# Generated public header (linked from src/Ilib.h by include/Makefile)
/include/Ilib.h

# GNU Autotools generated output (build inputs configure.ac / *.am are NOT ignored)
/configure
/config.h
/config.h.in
/config.log
/config.status
/config.guess
/config.sub
/stamp-h1
/aclocal.m4
/autom4te.cache/
/libtool
Makefile.in

# Autotools auxiliary files (usually symlinks installed by automake --add-missing)
/INSTALL
/depcomp
/install-sh
/missing
/compile
/ltmain.sh

# Built client/example binaries (installed names are ilib-*)
/ilib-font2h
/clients/ifont2h/ilib-font2h
/clients/ianim/ilib-anim
/clients/ichart/ilib-chart
/clients/idisplayfont/ilib-displayfont
/clients/ifraggraph/ilib-fraggraph
/clients/iindex/ilib-index
/clients/imogrify/ilib-mogrify
/clients/iwebreprt/ilib-webreprt
/examples/iconvert/ilib-convert
/examples/isample/ilib-sample

# Python bindings build artifacts
__pycache__/
*.py[cod]
/python/build/
/python/dist/
/python/src/*.egg-info/
/python/.pytest_cache/
